# Firebase (required for Firestore)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Mailgun (inbound + outbound)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SIGNING_KEY=

# Outbound: Mailgun (same key/domain as inbound)
# MAILGUN_API_KEY and MAILGUN_DOMAIN are used for sending the weekly recap

# Weekly recap recipients (comma-separated). Can also be set per week in Firestore.
SOPHIA_WEEKLY_RECIPIENTS=

# Optional: from address/name for sent emails
SOPHIA_WEEKLY_FROM_EMAIL=weekly@yourdomain.com
SOPHIA_WEEKLY_FROM_NAME=Goldie's Weekly

# Optional: auto-send when all 3 reports are in (true/false)
SOPHIA_WEEKLY_AUTO_SEND=false
